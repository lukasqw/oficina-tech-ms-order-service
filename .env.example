# =============================================================================
# MS2 — OS Service (Saga Orchestrator)
# Copie para .env e preencha os valores antes de rodar localmente
# =============================================================================

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8082

# ─── Banco de Dados ───────────────────────────────────────────────────────────
DB_HOST=localhost          # postgres-ms2 quando rodando via docker compose raiz
DB_PORT=5434               # 5432 quando rodando via docker-compose.yml individual
DB_USER=oficina
DB_PASSWORD=oficina
DB_NAME=db_ms2
DB_SSLMODE=disable

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Mesmo segredo compartilhado com MS1 e MS3 (validação local, sem chamada ao MS1)
JWT_SECRET_KEY=local-dev-secret

# ─── Endereços dos outros microsserviços ──────────────────────────────────────
MS1_BASE_URL=http://localhost:8081    # http://ms1:8080 dentro do Docker compose raiz
MS3_BASE_URL=http://localhost:8083    # http://ms3:8083 dentro do Docker compose raiz

# ─── AWS — LocalStack (desenvolvimento local) ─────────────────────────────────
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566   # http://localstack:4566 dentro do Docker

# ─── AWS Academy (produção) ───────────────────────────────────────────────────
# Substitua pelas credenciais da sessão AWS Academy (expiram a cada sessão)
# AWS_ACCESS_KEY_ID=<copiado do AWS Details>
# AWS_SECRET_ACCESS_KEY=<copiado do AWS Details>
# AWS_SESSION_TOKEN=<copiado do AWS Details>
# AWS_REGION=us-east-1
# (remova AWS_ENDPOINT_URL para apontar para a AWS real)

# ─── SQS Queues ───────────────────────────────────────────────────────────────
# Convenção do código: <QUEUE_NAME_UPPER>_QUEUE_URL
# (resolvido automaticamente via GetQueueUrl quando AWS_ENDPOINT_URL está definido)
ORDER_INVENTORY_OP_REQUESTED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-requested
ORDER_INVENTORY_OP_SUCCEEDED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-succeeded
ORDER_INVENTORY_OP_FAILED_QUEUE_URL=http://localhost:4566/000000000000/order-inventory-op-failed
CUSTOMER_DELETED_QUEUE_URL=http://localhost:4566/000000000000/customer-deleted

# ─── SMTP (notificações por email) ───────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@oficina-tech.com
SMTP_PASSWORD=senha-smtp
SMTP_FROM=noreply@oficina-tech.com

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=seu-webhook-secret
MP_NOTIFICATION_URL=https://api.oficina-tech.com/payments/mp-webhook
